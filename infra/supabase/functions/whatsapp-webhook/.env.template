# whatsapp-webhook function secrets
# Set via: supabase secrets set --project-ref dkccadwohifcqcdzhhnu \
#   GOWA_WEBHOOK_SECRET=<random-32-bytes-hex>

# HMAC-SHA256 shared secret with GOWA's WHATSAPP_WEBHOOK_SECRET env.
# Generate with: openssl rand -hex 32
GOWA_WEBHOOK_SECRET=

# Basic auth (user:pass) matching APP_BASIC_AUTH on the GOWA Railway
# service. The webhook fetches media bytes from GOWA, which serves them
# behind basic auth.
GOWA_BASIC_AUTH=

# These two are auto-set by Supabase for every Edge Function — do not override.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
