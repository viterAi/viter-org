# adapter-whatsapp-gowa env reference
# Copy to .env.local and fill in. NEVER commit .env.local.

# ─── GOWA service connection ────────────────────────────────────
# Public URL of the deployed GOWA service. Use the Railway-generated domain
# initially, then switch to your custom domain (gowa.viter.ai) once DNS lands.
GOWA_BASE_URL=https://gowa.viter.ai

# Basic auth that protects the GOWA admin UI (NOT the REST API).
# Format: username:password. Match this with APP_BASIC_AUTH on the GOWA side.
GOWA_BASIC_AUTH=admin:CHANGE_ME

# Shared HMAC secret for webhook verification.
# Match this with WHATSAPP_WEBHOOK_SECRET on the GOWA side AND with the
# Supabase Edge Function secret of the same name.
# Generate: openssl rand -hex 32
GOWA_WEBHOOK_SECRET=

# ─── Supabase (shared with the rest of vita) ────────────────────
SUPABASE_URL=https://dkccadwohifcqcdzhhnu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Backup storage ──────────────────────────────────────────────
GOWA_BACKUP_BUCKET=whatsapp-gowa-backups

# ─── Railway (for the backup-volume.ts script) ───────────────────
RAILWAY_TOKEN=
RAILWAY_SERVICE_ID=
