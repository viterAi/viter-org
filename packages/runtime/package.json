{
  "name": "@vita/runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./extractors": {
      "types": "./dist/extractors/index.d.ts",
      "default": "./dist/extractors/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types src/extractors/*.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.4"
  }
}
