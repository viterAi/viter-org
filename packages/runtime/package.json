{
  "name": "@vita/runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./extractors": {
      "types": "./dist/extractors/index.d.ts",
      "default": "./dist/extractors/index.js"
    },
    "./extractors-attachments": {
      "types": "./dist/extractors/attachments/dispatcher.d.ts",
      "default": "./src/extractors/attachments/dispatcher.ts"
    },
    "./extractors-meeting": {
      "types": "./dist/extractors/meeting/index.d.ts",
      "default": "./src/extractors/meeting/index.ts"
    },
    "./llm-log": {
      "types": "./dist/llm-log/index.d.ts",
      "default": "./src/llm-log/index.ts"
    },
    "./synthesizers": {
      "types": "./dist/synthesizers/index.d.ts",
      "default": "./dist/synthesizers/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test 'src/**/*.test.ts'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@supabase/supabase-js": "^2.45.0",
    "mammoth": "^1.12.0",
    "openai": "^4.73.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
