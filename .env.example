# Supabase — L0 (vita) project
# Browser-side (public, safe to expose)
NEXT_PUBLIC_L0_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_L0_SUPABASE_ANON_KEY=your-anon-key

# Server-side only
L0_SUPABASE_URL=https://your-project-id.supabase.co
L0_SUPABASE_ANON_KEY=your-anon-key
# Service-role key for THIS L0 project (get from Supabase → Project Settings → API).
# Must match the project in L0_SUPABASE_URL — do NOT use the UI-project service-role key here.
L0_SUPABASE_SERVICE_ROLE_KEY=your-l0-service-role-key
# Legacy alias kept for backwards compat; L0_SUPABASE_SERVICE_ROLE_KEY takes priority.
SUPABASE_SERVICE_ROLE_KEY=

# genUI ingest — Arcade relay and connect flow
# Arcade project secret: authenticates Arcade→your-app webhook relay (x-genui-forward-secret).
# Also used as the Arcade API key if ARCADE_API_KEY is not set separately.
GENUI_ARCADE_FORWARD_SECRET=
# Arcade Auth API key (from api.arcade.dev/dashboard). Used for OAuth connect flow.
ARCADE_API_KEY=
# Optional: Arcade forwarding URL to use as GitHub webhook target (if using Arcade relay).
# If unset, auto-installed webhooks point directly to NEXT_PUBLIC_APP_URL.
GENUI_ARCADE_WEBHOOK_URL=
# Optional fallback if per-repo secret not stored in DB
GITHUB_WEBHOOK_SECRET=
# Absolute public URL for the app (used as webhook base URL and OAuth redirect)
NEXT_PUBLIC_APP_URL=

# Tenant resolution for Corn jobs / genUI APIs (when user has no membership row)
# Default slug used only if NODE_ENV=development OR L0_ALLOW_TENANT_SLUG_FALLBACK=1
L0_DEFAULT_TENANT_SLUG=viter
# Set to 1 to map any signed-in user to L0_DEFAULT_TENANT_SLUG (single-tenant / internal only).
# Also allows L0_DEV_TENANT_ID without NODE_ENV=development (e.g. next start / preview demos).
L0_ALLOW_TENANT_SLUG_FALLBACK=
# UUID override when slug lookup is not used or fails; requires development OR L0_ALLOW_TENANT_SLUG_FALLBACK=1
L0_DEV_TENANT_ID=

# OpenRouter (AI layout generation + mail summarisation)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Cron worker auth — must also be set in Vercel dashboard → Environment Variables
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret
